{
  "compilerOptions": {
    "target": "ESNext",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ESNext"
    ],
    "types": [
      "vite/client",
      "node"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    /* Fixed Deprecations */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "noImplicitAny": false,
    /* Left false temporarily so legacy Arco types don't break */
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noUnusedLocals": false,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "isolatedModules": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    /* Explicitly define rootDir and outDir */
    "rootDir": "./src",
    "outDir": "lib",
    "paths": {
      "@extensions": [
        "./src"
      ],
      "@extensions/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "./src"
  ],
  "exclude": [
    "node_modules",
    "src/utils/__tests__"
  ]
}