{
  "name": "easy-email-core",
  "license": "MIT",
  "description": "Email editor",
  "version": "4.16.4",
  "author": "m-Ryan",
  "repository": {
    "type": "git",
    "url": "git@github.com:zalify/easy-email.git"
  },
  "keywords": [
    "email editor core"
  ],
  "files": [
    "lib"
  ],
  "main": "lib/index.cjs.js",
  "module": "lib/index.es.js",
  "types": "lib/index.d.ts",
  "scripts": {
    "dev": "yarn build --watch",
    "typings": "tsc --declaration --emitDeclarationOnly --project tsconfig.json && tsc-alias -p tsconfig.json",
    "build": "rimraf lib  && npm run typings && tsc-alias  && vite build --config vite.config.ts",
    "block": "ts-node -r tsconfig-paths/register scripts/generateBlockJSX.ts",
    "format": "eslint --fix  --ext .tsx,.ts,.tsx src/",
    "test": "jest  --coverage"
  },
  "husky": {
    "hooks": {
      "pre-commit": "yarn test && yarn lint-staged"
    }
  },
  "lint-staged": {
    "src/*.{js,jsx,ts,tsx}, example/*.{js,jsx,ts,tsx}": [
      "yarn lint"
    ]
  },
  "devDependencies": {
    "@babel/core": "^7.15.0",
    "@babel/preset-env": "^7.15.0",
    "@babel/preset-react": "^7.14.5",
    "@babel/preset-typescript": "^7.15.0",
    "@types/he": "^1.2.0",
    "@types/jest": "^26.0.24",
    "@types/js-beautify": "^1.13.3",
    "@types/jsdom": "^28.0.1",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.6.0",
    "@types/react": "^18.2.2",
    "@types/react-dom": "^18.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "babel-jest": "^27.0.6",
    "eslint": "9.26.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.23.4",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.24.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jest": "^27.0.6",
    "jsdom": "^29.0.2",
    "liquidjs": "10.25.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rimraf": "^6.1.3",
    "ts-node": "^10.4.0",
    "tsc-alias": "^1.4.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "vite": "8.0.5"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "he": "^1.2.0",
    "js-beautify": "^1.14.4",
    "lodash": "4.18.1",
    "uuid": "^13.0.0"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "gitHead": "f6cf54160ffdba0d4d6b23483293dd9190d2d2c2"
}
