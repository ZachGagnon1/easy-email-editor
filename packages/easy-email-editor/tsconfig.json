{
  "compilerOptions": {
    "target": "ESNext",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ESNext"
    ],
    "types": [
      "vite/client",
      "node"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    /* 1. Fixed Deprecation */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    /* 2. Removed alwaysStrict */

    "forceConsistentCasingInFileNames": true,
    "noUnusedLocals": false,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "isolatedModules": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    /* 3 & 4. Removed baseUrl, added rootDir explicitly */
    "rootDir": "./src",
    "outDir": "lib",
    "paths": {
      /* 5. Removed the cross-package aliases that caused the `..` error */
      "@": [
        "./src"
      ],
      "@/*": [
        "./src/*"
      ],
      "react": [
        "./node_modules/@types/react"
      ]
    }
  },
  "include": [
    "./src"
  ],
  "exclude": [
    "node_modules",
    "src/utils/__tests__"
  ]
}