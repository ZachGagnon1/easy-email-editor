{
  "name": "easy-email-editor",
  "license": "MIT",
  "description": "Email editor",
  "version": "4.16.3",
  "author": "m-Ryan",
  "repository": {
    "type": "git",
    "url": "git@github.com:zalify/easy-email.git"
  },
  "keywords": [
    "email editor core"
  ],
  "files": [
    "lib"
  ],
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "require": "./lib/index.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "typings": "tsc --declaration --emitDeclarationOnly --project tsconfig.json && tsc-alias -p tsconfig.json",
    "build": "rimraf lib && npm run typings && vite build --config vite.config.ts",
    "format": "eslint --fix  --ext .tsx,.ts,.tsx src/"
  },
  "husky": {
    "hooks": {
      "pre-commit": "yarn test && yarn lint-staged"
    }
  },
  "lint-staged": {
    "src/*.{js,jsx,ts,tsx}, example/*.{js,jsx,ts,tsx}": [
      "yarn lint"
    ]
  },
  "dependencies": {
    "@arco-themes/react-easy-email-theme": "^0.0.3",
    "@vitejs/plugin-react": "^6.0.1",
    "final-form": "^4.20.4",
    "final-form-arrays": "^3.0.2",
    "final-form-set-field-touched": "^1.0.1",
    "is-hotkey": "^0.2.0",
    "lodash": "4.18.1",
    "react-final-form-arrays": "^3.1.3",
    "react-use": "^17.3.1"
  },
  "devDependencies": {
    "@types/final-form-set-field-touched": "^1.0.0",
    "@types/is-hotkey": "^0.1.7",
    "@types/lodash": "^4.14.178",
    "@types/node": "^25.6.0",
    "@types/react": "^18.2.2",
    "@types/react-dom": "^18.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "esbuild": "^0.28.0",
    "eslint": "9.26.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.23.4",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.24.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "mjml-browser": "^4.10.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-final-form": "^6.5.7",
    "rimraf": "^6.1.3",
    "sass": "^1.99.0",
    "tsc-alias": "^1.4.1",
    "typescript": "^6.0.3",
    "vite": "8.0.5"
  },
  "peerDependencies": {
    "easy-email-core": "^4.3.6",
    "mjml-browser": "^4.10.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-final-form": "^6.5.7"
  },
  "gitHead": "2a08e8af15766344de708d891c1c8ea31bb77646"
}
