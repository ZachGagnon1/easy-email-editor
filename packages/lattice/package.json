{
  "name": "lattice",
  "license": "MIT",
  "description": "Lattice is a feature-rich, open-source SaaS email editor based on React and MJML.",
  "version": "1.0.0-beta.1",
  "author": "ZachGagnon1",
  "repository": {
    "type": "git",
    "url": "git@github.com:ZachGagnon1/Lattice.git"
  },
  "keywords": [
    "email editor core"
  ],
  "files": [
    "lib"
  ],
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "require": "./lib/index.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "typings": "tsc --project tsconfig.json && tsc-alias -p tsconfig.json",
    "build": "rimraf lib && npm run typings && vite build --config vite.config.ts",
    "format": "eslint --fix  --ext .tsx,.ts,.tsx src/"
  },
  "husky": {
    "hooks": {
      "pre-commit": "yarn test && yarn lint-staged"
    }
  },
  "lint-staged": {
    "src/*.{js,jsx,ts,tsx}, example/*.{js,jsx,ts,tsx}": [
      "yarn lint"
    ]
  },
  "dependencies": {
    "@arco-themes/react-easy-email-theme": "^0.0.3",
    "@base-ui/react": "^1.4.1",
    "@dnd-kit/react": "^0.4.0",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/roboto": "^5.2.10",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "@mui/x-tree-view": "^9.0.2",
    "@vitejs/plugin-react": "^6.0.1",
    "add": "^2.0.6",
    "codemirror": "^5.65.21",
    "color": "^5.0.3",
    "final-form": "^4.20.10",
    "final-form-arrays": "^3.1.0",
    "final-form-set-field-touched": "^1.0.1",
    "is-hotkey": "^0.2.0",
    "lodash": "4.18.1",
    "mjml-browser": "^4.18.0",
    "overlayscrollbars": "^1.13.3",
    "overlayscrollbars-react": "^0.3.0",
    "react-codemirror2": "^7.3.0",
    "react-color": "^2.19.3",
    "react-final-form-arrays": "^3.1.4",
    "react-is": "18.2.0",
    "react-use": "^17.6.0",
    "uuid": "14.0.0"
  },
  "devDependencies": {
    "@types/color": "^4.2.1",
    "@types/final-form-set-field-touched": "^1.0.3",
    "@types/is-hotkey": "^0.1.10",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.28",
    "@types/react-color": "^3.0.13",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "esbuild": "^0.28.0",
    "eslint": "9.26.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "he": "^1.2.0",
    "js-beautify": "^1.15.4",
    "mjml-browser": "^4.10.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-final-form": "^6.5.9",
    "rimraf": "^6.1.3",
    "sass": "^1.99.0",
    "tsc-alias": "^1.8.16",
    "typescript": "^6.0.3",
    "vite": "8.0.5"
  },
  "peerDependencies": {
    "mjml-browser": "^4.10.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-final-form": "^6.5.7"
  },
  "gitHead": "2a08e8af15766344de708d891c1c8ea31bb77646"
}
